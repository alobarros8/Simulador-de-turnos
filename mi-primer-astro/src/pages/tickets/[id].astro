---
// ============================================
// PÁGINA: DETALLE DE TICKET
// ============================================
// Ver detalles, delegar, resolver, agregar notas

import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { bd } from '../../lib/bd';
import { obtenerSesion } from '../../lib/sesion';

export const prerender = false;

// Verificar sesión
const sesion = obtenerSesion(Astro.cookies);
if (!sesion) {
	return Astro.redirect('/login');
}

const usuario = sesion.usuario;
const ticketId = Astro.params.id;

// Obtener ticket
const ticket = bd.obtenerTicket(ticketId!);
if (!ticket) {
	return Astro.response.writeHead(404);
}

let ticketoActualizado = ticket;
let ticketsSimilares: typeof ticket[] = [];
let error = '';
let mensaje = '';

// Buscar similares
ticketsSimilares = bd.buscarSimilares(ticket.descripcion, ticketId);

// Procesar acciones
if (Astro.request.method === 'POST') {
	try {
		const datos = await Astro.request.formData();
		const accion = datos.get('accion')?.toString();

		switch (accion) {
			// Delegar a presupuestador
			case 'delegar-presupuesto':
				const presupuestadorId = datos.get('presupuestadorId')?.toString();
				if (presupuestadorId) {
					bd.asignarTicket(ticketId!, presupuestadorId, 'presupuestador');
					mensaje = '✅ Ticket delegado a presupuestador';
				}
				break;

			// Delegar a técnico
			case 'delegar-tecnico':
				const tecnicoId = datos.get('tecnicoId')?.toString();
				if (tecnicoId) {
					bd.asignarTicket(ticketId!, tecnicoId, 'tecnico');
					mensaje = '✅ Ticket delegado a técnico';
				}
				break;

			// Agregar presupuesto
			case 'presupuesto':
				const presupuesto = parseFloat(datos.get('monto')?.toString() || '0');
				const razon = datos.get('razon')?.toString() || '';
				if (presupuesto > 0) {
					bd.generarPresupuesto(ticketId!, usuario.id, presupuesto, razon);
					mensaje = '✅ Presupuesto generado';
				}
				break;

			// Resolver ticket
			case 'resolver':
				const solucion = datos.get('solucion')?.toString() || '';
				if (solucion) {
					bd.resolverTicket(ticketId!, usuario.id, solucion);
					mensaje = '✅ Ticket marcado como resuelto';
				}
				break;

			// Agregar nota
			case 'nota':
				const contenido = datos.get('contenido')?.toString() || '';
				const esPublica = datos.get('publica') === 'on';
				if (contenido) {
					bd.agregarNota(ticketId!, usuario.id, usuario.nombre, contenido, esPublica);
					mensaje = '✅ Nota agregada';
				}
				break;
		}

		// Actualizar ticket
		ticketoActualizado = bd.obtenerTicket(ticketId!) || ticket;
	} catch (err) {
		error = '❌ Error al procesar la acción';
		console.error(err);
	}
}

// Deshabilitar acciones si no es admin
const esAdmin = usuario.rol === 'admin';
const puedeDelegar = esAdmin;
const puedeAgregarPresupuesto = usuario.rol === 'presupuestador' || esAdmin;
const puedeResolver = usuario.rol === 'tecnico' || esAdmin;

// Filtrar usuarios disponibles
const presupuestadores = bd.listarUsuarios().filter((u) => u.rol === 'presupuestador');
const tecnicos = bd.listarUsuarios().filter((u) => u.rol === 'tecnico');
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${ticketoActualizado.titulo} | ${SITE_TITLE}`} description={ticketoActualizado.descripcion} />
	</head>
	<body>
		<Header />

		<main class="contenedor-ticket">
			<!-- Barra norte -->
			<div class="barra-ticket">
				<a href="/dashboard" class="btn-volver">← Volver al dashboard</a>
				<span class="id-ticket">
					<code>ID: {ticketoActualizado.id}</code>
				</span>
			</div>

			{mensaje && (
				<div class="alerta-exito">
					{mensaje}
				</div>
			)}

			{error && (
				<div class="alerta-error">
					{error}
				</div>
			)}

			<div class="grid-contenido">
				<!-- Columna izquierda - Información del ticket -->
				<section class="columna-principal">
					<!-- Encabezado del ticket -->
					<div class="encabezado-ticket">
						<div>
							<h1>{ticketoActualizado.titulo}</h1>
							<p class="metadatos">
								<span class="badge categoria">{ticketoActualizado.categoria}</span>
								<span class="badge estado">{ticketoActualizado.estado}</span>
								<span class="badge prioridad">{ticketoActualizado.prioridad}</span>
							</p>
						</div>

						<div class="info-fechas">
							<div class="fecha">
								<small>Creado:</small>
								<strong>
									{new Date(ticketoActualizado.fechaCreacion).toLocaleDateString('es-ES')}
								</strong>
							</div>
							{ticketoActualizado.fechaResolucion && (
								<div class="fecha">
									<small>Resuelto:</small>
									<strong>
										{new Date(ticketoActualizado.fechaResolucion).toLocaleDateString('es-ES')}
									</strong>
								</div>
							)}
						</div>
					</div>

					<!-- Información del cliente -->
					<section class="tarjeta">
						<h3>👤 Información del Cliente</h3>
						<div class="cliente-info">
							<div class="info-row">
								<label>Nombre:</label>
								<strong>{ticketoActualizado.cliente?.nombre}</strong>
							</div>
							<div class="info-row">
								<label>Email:</label>
								<a href={`mailto:${ticketoActualizado.cliente?.email}`}>
									{ticketoActualizado.cliente?.email}
								</a>
							</div>
							{ticketoActualizado.cliente?.telefono && (
								<div class="info-row">
									<label>Teléfono:</label>
									<a href={`tel:${ticketoActualizado.cliente?.telefono}`}>
										{ticketoActualizado.cliente?.telefono}
									</a>
								</div>
							)}
							{ticketoActualizado.cliente?.empresa && (
								<div class="info-row">
									<label>Empresa:</label>
									<strong>{ticketoActualizado.cliente?.empresa}</strong>
								</div>
							)}
						</div>
					</section>

					<!-- Descripción del problema -->
					<section class="tarjeta">
						<h3>📝 Descripción del Problema</h3>
						<p class="descripcion">
							{ticketoActualizado.descripcion}
						</p>
					</section>

					<!-- Solución (si existe) -->
					{ticketoActualizado.solucion && (
						<section class="tarjeta solucion">
							<h3>✅ Solución Implementada</h3>
							<p>{ticketoActualizado.solucion}</p>
							<small>
								Resuelto por {bd.obtenerUsuario(ticketoActualizado.resueltoPor!)?.nombre}
							</small>
						</section>
					)}

					<!-- Tickets similares -->
					{ticketsSimilares.length > 0 && (
						<section class="tarjeta similares">
							<h3>🔄 Problemas Similares Anteriores</h3>
							<p class="hint">Estos tickets podrían tener soluciones que funcionaron antes:</p>
							<div class="tickets-similares">
								{ticketsSimilares.map((t) => (
									<a href={`/tickets/${t.id}`} class="ticket-similar">
										<div class="titulo-sim">{t.titulo}</div>
										<div class="estado-sim">{t.estado}</div>
										{t.solucion && <div class="tiene-solucion">✅ Tiene solución</div>}
									</a>
								))}
							</div>
						</section>
					)}

					<!-- Notas -->
					<section class="tarjeta">
						<h3>💬 Notas ({ticketoActualizado.notas.length})</h3>

						{ticketoActualizado.notas.length === 0 ? (
							<p class="sin-notas">No hay notas aún.</p>
						) : (
							<div class="lista-notas">
								{ticketoActualizado.notas.map((nota) => (
									<div class={`nota ${nota.esPublica ? 'publica' : 'privada'}`}>
										<div class="nota-encabezado">
											<strong>{nota.autorNombre}</strong>
											<span class="fecha">
												{new Date(nota.fecha).toLocaleString('es-ES')}
											</span>
											{nota.esPublica && <span class="badge-publica">Pública</span>}
										</div>
										<p class="nota-contenido">{nota.contenido}</p>
									</div>
								))}
							</div>
						)}

						<!-- Agregar nota -->
						<form method="POST" class="formulario-nota">
							<input type="hidden" name="accion" value="nota" />
							<div class="grupo">
								<label for="contenido">Agregar nota:</label>
								<textarea
									id="contenido"
									name="contenido"
									placeholder="Escribe una nota interna..."
									required
									minlength="5"
									rows="3"
								></textarea>
							</div>
							<div class="grupo-checkbox">
								<input type="checkbox" id="publica" name="publica" />
								<label for="publica">Mostrar al cliente</label>
							</div>
							<button type="submit" class="btn-pequeño">
								📝 Agregar nota
							</button>
						</form>
					</section>
				</section>

				<!-- Columna derecha - Acciones -->
				<aside class="columna-acciones">
					<!-- Presupuesto -->
					{puedeAgregarPresupuesto && (
						<section class="tarjeta-accion">
							<h3>💵 Presupuesto</h3>
							{ticketoActualizado.presupuesto ? (
								<div class="presupuesto-info">
									<div class="monto">$ {ticketoActualizado.presupuesto.toFixed(2)}</div>
									<p class="razon">{ticketoActualizado.razonPresupuesto}</p>
									<small>
										Por: {bd.obtenerUsuario(ticketoActualizado.presupuestadoPor!)?.nombre}
									</small>
								</div>
							) : (
								<form method="POST" class="formulario-accion">
									<input type="hidden" name="accion" value="presupuesto" />
									<div class="grupo">
										<label for="monto">Monto ($)</label>
										<input
											type="number"
											id="monto"
											name="monto"
											placeholder="0.00"
											step="0.01"
											required
										/>
									</div>
									<div class="grupo">
										<label for="razon">Razón</label>
										<textarea
											id="razon"
											name="razon"
											placeholder="Explica el costo..."
											rows="2"
										></textarea>
									</div>
									<button type="submit" class="btn-accion">
										Generar presupuesto
									</button>
								</form>
							)}
						</section>
					)}

					<!-- Delegar -->
					{puedeDelegar && (
						<>
							<section class="tarjeta-accion">
								<h3>👩‍💼 Delegar a Presupuestador</h3>
								{presupuestadores.length === 0 ? (
									<p class="sin-opciones">No hay presupuestadores disponibles</p>
								) : (
									<form method="POST" class="formulario-accion">
										<input type="hidden" name="accion" value="delegar-presupuesto" />
										<div class="grupo">
											<select name="presupuestadorId" required>
												<option value="">-- Selecciona --</option>
												{presupuestadores.map((p) => (
													<option value={p.id}>
														{p.nombre}
													</option>
												))}
											</select>
										</div>
										<button type="submit" class="btn-accion">
											📤 Delegar
										</button>
									</form>
								)}
							</section>

							<section class="tarjeta-accion">
								<h3>🔧 Delegar a Técnico</h3>
								{tecnicos.length === 0 ? (
									<p class="sin-opciones">No hay técnicos disponibles</p>
								) : (
									<form method="POST" class="formulario-accion">
										<input type="hidden" name="accion" value="delegar-tecnico" />
										<div class="grupo">
											<select name="tecnicoId" required>
												<option value="">-- Selecciona --</option>
												{tecnicos.map((t) => (
													<option value={t.id}>
														{t.nombre}
													</option>
												))}
											</select>
										</div>
										<button type="submit" class="btn-accion">
											📤 Delegar
										</button>
									</form>
								)}
							</section>
						</>
					)}

					<!-- Resolver -->
					{puedeResolver && !ticketoActualizado.solucion && (
						<section class="tarjeta-accion">
							<h3>✅ Resolver Ticket</h3>
							<form method="POST" class="formulario-accion">
								<input type="hidden" name="accion" value="resolver" />
								<div class="grupo">
									<label for="solucion">Solución aplicada</label>
									<textarea
										id="solucion"
										name="solucion"
										placeholder="Describe cómo se resolvió el problema..."
										required
										rows="4"
									></textarea>
								</div>
								<button type="submit" class="btn-accion btn-exito">
									✅ Marcar como resuelto
								</button>
							</form>
						</section>
					)}

					<!-- Info de asignación -->
					{ticketoActualizado.asignadoA && (
						<section class="tarjeta-info">
							<h3>👤 Asignado a</h3>
							<div class="asignado-a">
								{bd.obtenerUsuario(ticketoActualizado.asignadoA)?.nombre}
							</div>
							<small>Rol: {ticketoActualizado.asignadoUnidadA}</small>
						</section>
					)}
				</aside>
			</div>
		</main>

		<Footer />
	</body>
</html>

<style>
	.contenedor-ticket {
		max-width: 1400px;
		margin: 0 auto;
		padding: 2rem;
	}

	.barra-ticket {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
	}

	.btn-volver {
		padding: 0.8rem 1.5rem;
		background: #667eea;
		color: white;
		text-decoration: none;
		border-radius: 6px;
		transition: all 0.3s ease;
	}

	.btn-volver:hover {
		background: #5568d3;
		transform: translateY(-2px);
	}

	.id-ticket code {
		background: #f4f4f4;
		padding: 0.5rem 1rem;
		border-radius: 6px;
		color: #667eea;
		font-weight: bold;
	}

	.alerta-exito {
		background: #d4edda;
		border: 2px solid #c3e6cb;
		color: #155724;
		padding: 1rem;
		border-radius: 6px;
		margin-bottom: 2rem;
		animation: slideDown 0.3s ease;
	}

	.alerta-error {
		background: #f8d7da;
		border: 2px solid #f5c6cb;
		color: #721c24;
		padding: 1rem;
		border-radius: 6px;
		margin-bottom: 2rem;
		animation: slideDown 0.3s ease;
	}

	@keyframes slideDown {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.grid-contenido {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 2rem;
	}

	.tarjeta {
		background: white;
		border-radius: 8px;
		padding: 1.5rem;
		border: 1px solid #ddd;
		margin-bottom: 2rem;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
	}

	.tarjeta h3 {
		margin: 0 0 1rem 0;
		color: #333;
		font-size: 1.2rem;
	}

	.encabezado-ticket {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	.encabezado-ticket h1 {
		margin: 0 0 0.5rem 0;
		color: #333;
		font-size: 2rem;
	}

	.metadatos {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
		margin: 0;
	}

	.badge {
		display: inline-block;
		padding: 0.4rem 0.8rem;
		border-radius: 20px;
		font-size: 0.85rem;
		font-weight: 600;
		text-transform: capitalize;
	}

	.badge.categoria {
		background: #e7d4f5;
		color: #663399;
	}

	.badge.estado {
		background: #cfe9ff;
		color: #004085;
	}

	.badge.prioridad {
		background: #fff3cd;
		color: #856404;
	}

	.info-fechas {
		display: flex;
		gap: 2rem;
		text-align: right;
	}

	.fecha small {
		display: block;
		color: #999;
		font-size: 0.85rem;
	}

	.fecha strong {
		display: block;
		color: #333;
	}

	.cliente-info {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
	}

	.info-row {
		display: grid;
		grid-template-columns: 100px 1fr;
		gap: 1rem;
	}

	.info-row label {
		font-weight: 600;
		color: #666;
	}

	.info-row a {
		color: #667eea;
		text-decoration: none;
	}

	.info-row a:hover {
		text-decoration: underline;
	}

	.descripcion {
		color: #333;
		line-height: 1.8;
		margin: 0;
		padding: 1rem;
		background: #f8f9fa;
		border-radius: 6px;
		border-left: 4px solid #667eea;
	}

	.tarjeta.solucion {
		background: #d4edda;
		border: 2px solid #c3e6cb;
	}

	.tarjeta.solucion p {
		color: #155724;
	}

	.tarjeta.solucion small {
		color: #155724;
		opacity: 0.8;
	}

	.tarjeta.similares .hint {
		color: #666;
		font-size: 0.9rem;
		margin-bottom: 1rem;
	}

	.tickets-similares {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
	}

	.ticket-similar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem;
		background: #f8f9fa;
		border-radius: 6px;
		text-decoration: none;
		color: inherit;
		transition: all 0.3s ease;
		border: 1px solid #eee;
	}

	.ticket-similar:hover {
		background: white;
		border-color: #667eea;
		box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
	}

	.titulo-sim {
		font-weight: 600;
		color: #333;
		flex: 1;
	}

	.estado-sim {
		color: #999;
		font-size: 0.9rem;
		text-transform: capitalize;
	}

	.tiene-solucion {
		background: #d4edda;
		color: #155724;
		padding: 0.3rem 0.8rem;
		border-radius: 20px;
		font-size: 0.85rem;
		font-weight: 600;
		margin-left: 1rem;
	}

	.sin-notas {
		color: #999;
		font-style: italic;
	}

	.lista-notas {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.nota {
		padding: 1rem;
		border-radius: 6px;
		border-left: 3px solid #667eea;
		background: #f8fbff;
	}

	.nota.privada {
		border-left-color: #ffc107;
		background: #fffacd;
	}

	.nota-encabezado {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 0.5rem;
		flex-wrap: wrap;
	}

	.nota strong {
		color: #333;
	}

	.fecha {
		font-size: 0.85rem;
		color: #999;
	}

	.badge-publica {
		background: #ffc107;
		color: white;
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.nota-contenido {
		margin: 0;
		color: #333;
	}

	.formulario-nota {
		background: #f8f9fa;
		padding: 1rem;
		border-radius: 6px;
		border: 1px solid #ddd;
	}

	.grupo {
		margin-bottom: 1rem;
		display: flex;
		flex-direction: column;
	}

	.grupo label {
		font-weight: 600;
		margin-bottom: 0.3rem;
		color: #333;
	}

	.grupo textarea {
		padding: 0.8rem;
		border: 1px solid #ddd;
		border-radius: 6px;
		font-family: inherit;
		resize: vertical;
	}

	.grupo-checkbox {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.grupo-checkbox input {
		cursor: pointer;
	}

	.btn-pequeño {
		padding: 0.6rem 1.2rem;
		background: #667eea;
		color: white;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.btn-pequeño:hover {
		background: #5568d3;
		transform: translateY(-1px);
	}

	/* Columna de acciones */
	.columna-acciones {
		display: flex;
		flex-direction: column;
	}

