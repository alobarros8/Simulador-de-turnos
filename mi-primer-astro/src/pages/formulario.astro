---
// ===========================================
// PÁGINA DE FORMULARIO
// ===========================================
// Demuestra cómo usar el componente de formulario

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Formulario from '../components/Formulario.astro';
import { SITE_TITLE } from '../consts';

// Información para la página
const titulo = 'Formularios en Astro';
const descripcion = 'Aprende a crear formularios HTML en Astro';

// Información del servidor (esto se ejecuta solo en compilación)
let respuestaEnviada = false;
const datosEnviados: Record<string, string> = {};

// Procesar el formulario si viene una solicitud POST
if (Astro.request.method === 'POST') {
	try {
		const datos = await Astro.request.formData();
		
		// Convertir FormData a objeto normal
		for (const [key, value] of datos) {
			datosEnviados[key] = value as string;
		}
		
		respuestaEnviada = true;
	} catch (error) {
		console.error('Error al procesar formulario:', error);
	}
}
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${titulo} | ${SITE_TITLE}`} description={descripcion} />
	</head>
	<body>
		<Header />
		
		<main>
			<!-- Sección de explicación -->
			<section class="seccion-info">
				<h1>📝 {titulo}</h1>
				<p class="descripcion">{descripcion}</p>

				<div class="info-box">
					<h3>✨ Características del formulario:</h3>
					<ul>
						<li>✅ Validación HTML5 integrada</li>
						<li>✅ Estilos con Tailwind compatible</li>
						<li>✅ Accesibilidad (ARIA labels)</li>
						<li>✅ Campos: texto, email, teléfono, select, textarea, checkbox, radio</li>
						<li>✅ Responsive en móviles</li>
						<li>✅ Mensajes de ayuda para cada campo</li>
					</ul>
				</div>
			</section>

			<!-- Mostrar respuesta si se envió el formulario -->
			{respuestaEnviada && (
				<section class="respuesta-exitosa">
					<h2>✅ ¡Formulario enviado correctamente!</h2>
					<p>Aquí están los datos que recibimos:</p>
					
					<div class="datos-tabla">
						{Object.entries(datosEnviados).map(([clave, valor]) => (
							<div class="dato-row">
								<strong>{clave}:</strong>
								<span>{valor === 'on' ? '✓ Marcado' : valor}</span>
							</div>
						))}
					</div>

					<details style="margin-top: 1.5rem;">
						<summary>¿Cómo se procesan los formularios?</summary>
						<pre><code>{`
// En Astro, captura el método POST así:
if (Astro.request.method === 'POST') {
  const datos = await Astro.request.formData();
  
  for (const [key, value] of datos) {
    console.log(key, value);
  }
}

// Astro es Full Stack - puede procesar formularios
// sin necesidad de una API separada
						`}</code></pre>
					</details>
				</section>
			)}

			<!-- Componente del formulario -->
			<section class="seccion-formulario">
				<Formulario 
					titulo="Formulario de Contacto Interactivo"
					metodo="POST"
					accion="/formulario"
				/>
			</section>

			<!-- Sección educativa -->
			<section class="seccion-educativa">
				<h2>📚 Cómo crear un formulario en Astro</h2>

				<article>
					<h3>1️⃣ Crear el componente</h3>
					<pre><code>{`
// src/components/Formulario.astro
---
interface Props {
  titulo?: string;
}

const { titulo = 'Mi Formulario' } = Astro.props;
---

<form method="POST" action="/mi-pagina">
  <input type="text" name="nombre" required />
  <button type="submit">Enviar</button>
</form>
					`}</code></pre>
				</article>

				<article>
					<h3>2️⃣ Importarlo en una página</h3>
					<pre><code>{`
// src/pages/contacto.astro
---
import Formulario from '../components/Formulario.astro';
---

<html>
  <body>
    <Formulario titulo="Contáctame" />
  </body>
</html>
					`}</code></pre>
				</article>

				<article>
					<h3>3️⃣ Procesar el POST en la misma página</h3>
					<pre><code>{`
---
// Procesar formulario
if (Astro.request.method === 'POST') {
  const datos = await Astro.request.formData();
  const nombre = datos.get('nombre');
  
  // Guardar en BD, enviar email, etc.
  console.log('Nombre:', nombre);
}
---

<Formulario />
					`}</code></pre>
				</article>

				<article>
					<h3>4️⃣ Tipos de inputs disponibles</h3>
					<div class="tipos-inputs">
						<div class="tipo">
							<strong>text</strong>
							<code>{'<input type="text" />'}</code>
						</div>
						<div class="tipo">
							<strong>email</strong>
							<code>{'<input type="email" />'}</code>
						</div>
						<div class="tipo">
							<strong>tel</strong>
							<code>{'<input type="tel" />'}</code>
						</div>
						<div class="tipo">
							<strong>number</strong>
							<code>{'<input type="number" />'}</code>
						</div>
						<div class="tipo">
							<strong>password</strong>
							<code>{'<input type="password" />'}</code>
						</div>
						<div class="tipo">
							<strong>checkbox</strong>
							<code>{'<input type="checkbox" />'}</code>
						</div>
						<div class="tipo">
							<strong>radio</strong>
							<code>{'<input type="radio" />'}</code>
						</div>
						<div class="tipo">
							<strong>select</strong>
							<code>{'<select><option /></select>'}</code>
						</div>
						<div class="tipo">
							<strong>textarea</strong>
							<code>{'<textarea></textarea>'}</code>
						</div>
					</div>
				</article>

				<article>
					<h3>5️⃣ Validaciones HTML5</h3>
					<pre><code>{`
<!-- Campo requerido -->
<input type="text" required />

<!-- Email válido -->
<input type="email" required />

<!-- Patrón personalizado -->
<input type="tel" pattern="[0-9+\-\s]+" />

<!-- Longitud mínima y máxima -->
<textarea minlength="10" maxlength="500"></textarea>

<!-- Número con rango -->
<input type="number" min="1" max="100" />

<!-- Placeholder -->
<input placeholder="Tu nombre aquí" />
					`}</code></pre>
				</article>
			</section>

			<!-- Navegación -->
			<nav class="navegacion">
				<a href="/experimentos">← Volver a Experimentos</a>
				<a href="/">Ir a Inicio</a>
			</nav>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
	}

	section {
		margin: 2rem 0;
	}

	h1 {
		color: #333;
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
		text-align: center;
	}

	.descripcion {
		text-align: center;
		color: #666;
		font-size: 1.1rem;
		margin-bottom: 2rem;
	}

	.seccion-info {
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		padding: 2rem;
		border-radius: 12px;
		margin-bottom: 2rem;
	}

	.seccion-info h1 {
		color: white;
		margin: 0 0 1rem 0;
	}

	.info-box {
		background: rgba(255, 255, 255, 0.1);
		padding: 1.5rem;
		border-radius: 8px;
		backdrop-filter: blur(10px);
	}

	.info-box h3 {
		margin-top: 0;
		font-size: 1.3rem;
	}

	.info-box ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.info-box li {
		padding: 0.5rem 0;
		font-size: 1rem;
	}

	.respuesta-exitosa {
		background: #d4edda;
		border: 2px solid #28a745;
		padding: 2rem;
		border-radius: 12px;
		margin-bottom: 2rem;
	}

	.respuesta-exitosa h2 {
		color: #155724;
		margin-top: 0;
	}

	.datos-tabla {
		background: white;
		padding: 1.5rem;
		border-radius: 8px;
		margin: 1rem 0;
	}

	.dato-row {
		display: flex;
		justify-content: space-between;
		padding: 0.8rem;
		border-bottom: 1px solid #e0e0e0;
	}

	.dato-row:last-child {
		border-bottom: none;
	}

	.dato-row strong {
		color: #333;
		text-transform: capitalize;
	}

	.dato-row span {
		color: #28a745;
		font-weight: 600;
	}

	.seccion-formulario {
		margin: 3rem 0;
	}

	.seccion-educativa {
		margin-top: 3rem;
	}

	.seccion-educativa h2 {
		text-align: center;
		color: #333;
		margin-bottom: 2rem;
	}

	article {
		background: #f8f9fa;
		padding: 1.5rem;
		border-radius: 8px;
		margin-bottom: 1.5rem;
		border-left: 4px solid #667eea;
	}

	article h3 {
		color: #667eea;
		margin-top: 0;
	}

	pre {
		background: #2d3436;
		color: #a29bfe;
		padding: 1rem;
		border-radius: 6px;
		overflow-x: auto;
		font-size: 0.9rem;
	}

	code {
		font-family: 'Courier New', monospace;
		color: #a29bfe;
	}

	.tipos-inputs {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1rem;
		margin: 1rem 0;
	}

	.tipo {
		background: white;
		padding: 1rem;
		border-radius: 6px;
		border: 1px solid #ddd;
	}

	.tipo strong {
		display: block;
		color: #667eea;
		margin-bottom: 0.5rem;
		font-size: 1.1rem;
	}

	.tipo code {
		display: block;
		font-size: 0.85rem;
		background: #f5f5f5;
		padding: 0.5rem;
		border-radius: 4px;
		word-break: break-all;
	}

	.navegacion {
		display: flex;
		justify-content: center;
		gap: 2rem;
		margin: 3rem 0;
		padding: 2rem;
		background: #f5f5f5;
		border-radius: 8px;
	}

	.navegacion a {
		padding: 0.8rem 1.5rem;
		background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		color: white;
		text-decoration: none;
		border-radius: 6px;
		transition: transform 0.3s ease;
	}

	.navegacion a:hover {
		transform: translateY(-2px);
	}

	details {
		background: #f5f5f5;
		padding: 1rem;
		border-radius: 6px;
		cursor: pointer;
	}

	details summary {
		color: #667eea;
		font-weight: bold;
		cursor: pointer;
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 1.8rem;
		}

		.navegacion {
			flex-direction: column;
		}

		main {
			padding: 1rem;
		}
	}
</style>
